# Your Verifone User UUID (found in the portal under account/profile)
VERIFONE_USER_UUID=your-user-uuid-here

# Your Verifone API Key
VERIFONE_API_KEY=your-api-key-here

# Optional: email to include in the report notification field
VERIFONE_NOTIFICATION_EMAIL=

# The date to start fetching from on the very first run (ISO 8601 UTC)
INITIAL_START_DATE=2025-01-01T00:00:00.000Z

# Path to the SQLite database file (relative to working directory)
DB_PATH=transactions.db

# ---------------------------------------------------------------------------
# Instagram Graph API
# ---------------------------------------------------------------------------

# Facebook app credentials
INSTAGRAM_APP_ID=your-app-id
INSTAGRAM_APP_SECRET=your-app-secret

# Long-lived user access token (see docs/INSTAGRAM_SETUP.md)
INSTAGRAM_ACCESS_TOKEN=your-long-lived-token

# Facebook Page ID linked to the Instagram account
INSTAGRAM_PAGE_ID=your-page-id

# Instagram Business/Creator account ID (numeric, e.g. 17841400000000000)
INSTAGRAM_USER_ID=your-ig-user-id

# Date to start fetching Instagram media from on the first run (ISO 8601 UTC)
INSTAGRAM_INITIAL_START_DATE=2025-01-01T00:00:00.000Z
